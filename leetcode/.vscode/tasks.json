{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "C++: g++ build active file",
      "type": "shell",
      "command": "E:/DataAPPs/mingw64/bin/g++.exe",
      "args": [
        "-std=c++17",
        "-O2",
        "-Wall",
        "-Wextra",
        "-g",
        "${file}",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}.exe"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": [
        "$gcc"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "Build active C++ file with MinGW g++"
    },
    {
      "label": "C++: build and run active file",
      "type": "shell",
      "dependsOn": "C++: g++ build active file",
      "command": "${fileDirname}/${fileBasenameNoExtension}.exe",
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": [],
      "group": "test",
      "detail": "Build then run active C++ file"
    }
  ]
}
